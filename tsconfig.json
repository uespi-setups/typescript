  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.cache/tsconfig.app.tsbuildinfo",
    "types": ["node", "vitest/globals"]
