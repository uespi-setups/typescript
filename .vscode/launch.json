{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug main.ts",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/src/main.ts",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Active File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${file}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
